# =============================================================================
# Chronos Seed Node — Omgevingsvariabelen
# Kopieer dit bestand naar .env.seed en vul de waarden in.
# =============================================================================

# VEREIST: Tailscale auth key
# Genereer via: https://login.tailscale.com/admin/authkeys
# Kies: Reusable=true, No expiry, Tag: tag:chronos (optioneel)
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optioneel: naam van de machine in je Tailscale netwerk
# De seed node is dan bereikbaar via: chronos-seed.<tailnet>.ts.net
TS_HOSTNAME=chronos-seed
